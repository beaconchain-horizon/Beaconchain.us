# ============================================================
# Horizon Core Engine – Environment Variables (Example)
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to the repository!
# ============================================================

# ------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------
PORT=8080
ENVIRONMENT=development  # development | staging | production
LOG_LEVEL=info           # debug | info | warn | error

# ------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------
# Format: postgresql://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgresql://beaconchain:beaconchain123@localhost:5432/beaconchain?sslmode=disable

# ------------------------------------------------------------
# External APIs
# ------------------------------------------------------------
# CoinGecko – for live crypto prices
COINGECKO_API_KEY=your_coingecko_api_key_here
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Beaconcha.in – for validator data
BEACONCHAIN_API_URL=https://api.beaconcha.in/api/v1
BEACONCHAIN_API_KEY=your_beaconchain_api_key_here

# Infura – for Ethereum blockchain access
INFURA_PROJECT_ID=your_infura_project_id_here

# ------------------------------------------------------------
# License & Security
# ------------------------------------------------------------
# ECDSA private key (base64 encoded) – used for signing licenses
# Generate with: openssl ecparam -name secp256k1 -genkey -noout | base64
ECDSA_PRIVATE_KEY=your_base64_ecdsa_private_key_here

# Merkle tree salt (optional, for extra randomness)
MERKLE_SALT=your_secure_random_salt_here

# Session secret for authentication (min 32 characters)
SESSION_SECRET=your_super_secret_key_min_32_chars_here

# ------------------------------------------------------------
# Webhook & GitHub Integration
# ------------------------------------------------------------
WEBHOOK_PORT=8080
WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=beaconchain-horizon/horizon-core-engine

# ------------------------------------------------------------
# Frontend / CORS
# ------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://beaconchain.us,https://beaconchain-horizon.github.io
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS

# ------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60  # seconds

# ------------------------------------------------------------
# Optional: Prefect Cloud (if you use Prefect for orchestration)
# ------------------------------------------------------------
PREFECT_API_KEY=your_prefect_api_key_here
PREFECT_WORKSPACE=beaconchain/prod

# ------------------------------------------------------------
# Admin & Monitoring
# ------------------------------------------------------------
ADMIN_EMAIL=admin@beaconchain.us
CSP_REPORT_URI=https://beaconchain.us/csp-report

# ------------------------------------------------------------
# Redis (for caching, optional)
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379
