# Beaconchain Horizon Security Configuration
# Copy to .env.local for production

# API Keys (use backend proxy, never expose to frontend)
BEACONCHAIN_API_KEY=your_api_key_here
INFURA_PROJECT_ID=your_infura_id

# Database (if using backend)
DATABASE_URL=postgresql://user:pass@localhost:5432/beaconchain
REDIS_URL=redis://localhost:6379

# Security
SESSION_SECRET=your_super_secret_key_min_32_chars
CSP_REPORT_URI=https://beaconchain.us/csp-report

# Admin
ADMIN_EMAIL=admin@beaconchain.us
