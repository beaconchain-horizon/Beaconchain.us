        }
        .certificate-title .sub {
            font-size: 0.9rem;
            font-weight: 400;
            color: #475569;
            margin-top: 0.25rem;
        }
        .certificate-meta {
            text-align: left;
            font-size: 0.8rem;
            color: #475569;
            line-height: 1.6;
            background: #f8fafc;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            border: 1px solid #e2e8f0;
            min-width: 200px;
        }
        .certificate-meta strong {
            color: #0f172a;
        }
        .section-title {
            font-size: 1.3rem;
            font-weight: 700;
            color: #0f172a;
            margin: 2rem 0 1rem 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .section-title .badge {
            font-size: 0.7rem;
            background: #2563eb;
            color: white;
            padding: 0.15rem 0.8rem;
            border-radius: 20px;
            font-weight: 600;
        }
        .table-wrap {
            overflow-x: auto;
            margin: 1rem 0 1.5rem 0;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            background: #fafbfc;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.9rem;
        }
        th {
            background: #f1f5f9;
            text-align: right;
            padding: 0.75rem 1.2rem;
            font-weight: 700;
            color: #1e293b;
            border-bottom: 2px solid #e2e8f0;
        }
        td {
            padding: 0.7rem 1.2rem;
            border-bottom: 1px solid #eef2f6;
            color: #1e293b;
        }
        tr:last-child td {
            border-bottom: none;
        }
        .status-badge {
            display: inline-block;
            background: #dcfce7;
            color: #166534;
            font-weight: 700;
            padding: 0.1rem 0.8rem;
            border-radius: 20px;
            font-size: 0.8rem;
