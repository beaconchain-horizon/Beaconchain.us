      color: #cbd5e1;
    }
    button { background: #4f9eff; border: none; padding: 0.5rem 1rem; border-radius: 2rem; cursor: pointer; font-weight: bold; margin-top: 1rem; }
    .demo { background: #1e293b; border-radius: 1rem; padding: 1rem; }
    .output { background: #0f172a; border-radius: 1rem; padding: 0.5rem; font-family: monospace; margin-top: 0.5rem; }
    .footer { text-align: center; margin-top: 2rem; font-size: 0.7rem; }
  </style>
